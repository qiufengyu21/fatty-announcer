# ===== KOOK 机器人配置 =====

# 机器人 Token（必填）
# 获取方式：开发者中心 -> 应用 -> 你的应用 -> 机器人 -> Token
# 形如：1/MTA4O...=/xxxxxxxxxxxxxxxxxxxx==
KOOK_BOT_TOKEN=

# 可选：自定义 ffmpeg 可执行文件路径
# 留空则自动使用内置的 ffmpeg-static，找不到时再回退到系统 PATH 中的 ffmpeg
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# 可选：自定义配置文件路径（默认为 config.json）
# CONFIG_PATH=config.json
